# Google Shopping through SerpAPI
SERPAPI_API_KEY=...
WEB_SEARCH_DEFAULT_METHOD=google_shopping

# Optional preferred ecommerce domains
WEB_SEARCH_SITES=digikey.com,mouser.com

# Keep unset unless you have a real corporate proxy configured.
# The app automatically ignores the dead local proxy http://127.0.0.1:9.
# WEB_SEARCH_USE_SYSTEM_PROXY=true
