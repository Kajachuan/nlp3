# Google Shopping through SerpAPI
SERPAPI_API_KEY=...
WEB_SEARCH_DEFAULT_METHOD=google_shopping

# Groq / LangChain / LangGraph
GROQ_API_KEY=...
LLM_MODEL_OPTIONS=canopylabs/orpheus-arabic-saudi,canopylabs/orpheus-v1-english,groq/compound,groq/compound-mini,llama-3.1-8b-instant,llama-3.3-70b-versatile,meta-llama/llama-4-scout-17b-16e-instruct,meta-llama/llama-prompt-guard-2-22m,meta-llama/llama-prompt-guard-2-86m,openai/gpt-oss-120b,openai/gpt-oss-20b,openai/gpt-oss-safeguard-20b
PLANNER_MODEL=openai/gpt-oss-120b
DIRECT_RESPONSE_MODEL=groq/compound-mini
VERIFIER_MODEL=groq/compound

# Langfuse Cloud/Web through the Python SDK
LANGFUSE_PUBLIC_KEY=...
LANGFUSE_SECRET_KEY=...
LANGFUSE_HOST=https://cloud.langfuse.com

# Local evidence gate
LOCAL_SEARCH_MIN_SCORE=0.08
LOCAL_SEARCH_MIN_RESULTS=1
WEB_FALLBACK_ENABLED=true
LOCAL_COMPONENT_PAGE_BASE_URL=http://localhost:5500/llm-agent-project/web/componentes.html

# Optional preferred ecommerce domains
WEB_SEARCH_SITES=digikey.com,mouser.com

# Keep unset unless you have a real corporate proxy configured.
# The app automatically ignores the dead local proxy http://127.0.0.1:9.
# WEB_SEARCH_USE_SYSTEM_PROXY=true
